<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widgetRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="8dp"
    android:background="@drawable/widget_bg">

    <!-- ── Nom de la mosquée (centré, haut du widget) ── -->
    <TextView
        android:id="@+id/widgetMosqueName"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.7"
        android:text="—"
        android:textColor="#ffd35a"
        android:textSize="12sp"
        android:textStyle="bold"
        android:gravity="center"
        android:maxLines="1"
        android:ellipsize="end" />

    <!-- ── Zone d'en-tête : soit l'affichage normal (compte à rebours | date | -->
    <!-- chourouq), soit le message de phase azan/doaa/iqama — un seul des -->
    <!-- deux est visible à la fois (cf. TawkitWidgetProvider.computePhase). -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.4">

        <LinearLayout
            android:id="@+id/widgetHeaderNormal"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Compte à rebours prochaine prière -->
            <TextView
                android:id="@+id/widgetNextPrayer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.5"
                android:text="—"
                android:textColor="#ffd35a"
                android:textSize="13sp"
                android:textStyle="bold"
                android:gravity="start"
                android:maxLines="2" />

            <!-- Cadre dates (hijri sur 1-2 lignes + miladi) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="2"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="4dp"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/widget_date_bg">

                <TextView
                    android:id="@+id/widgetHijriDate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#f5e6c8"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:maxLines="2"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/widgetGregorianDate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#c8a86a"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:maxLines="1"
                    android:ellipsize="end" />
            </LinearLayout>

            <!-- Heure chourouq -->
            <TextView
                android:id="@+id/widgetSunrise"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.5"
                android:text="—"
                android:textColor="#ff9955"
                android:textSize="13sp"
                android:textStyle="bold"
                android:gravity="end"
                android:maxLines="1" />
        </LinearLayout>

        <!-- Message de phase (avant azan / azan / doaa / attente iqama) -->
        <LinearLayout
            android:id="@+id/widgetHeaderPhase"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:id="@+id/widgetPhaseName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="#ffd35a"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/widgetPhaseDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#f5e6c8"
                android:textSize="11sp"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>
    </FrameLayout>

    <!-- ── Séparateur ── -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#4a3820"
        android:text="" />

    <!-- ── Ligne 2 : noms des 5 prières (ordre RTL : Isha → Fajr) ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView android:id="@+id/widgetNameIsha"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:text="العشاء" android:textColor="#c8a86a" android:textSize="12sp"
            android:gravity="center" android:maxLines="1" />

        <TextView android:id="@+id/widgetNameMgrb"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:text="المغرب" android:textColor="#c8a86a" android:textSize="12sp"
            android:gravity="center" android:maxLines="1" />

        <TextView android:id="@+id/widgetNameAssr"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:text="العصر" android:textColor="#c8a86a" android:textSize="12sp"
            android:gravity="center" android:maxLines="1" />

        <TextView android:id="@+id/widgetNameDohr"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:text="الظهر" android:textColor="#c8a86a" android:textSize="12sp"
            android:gravity="center" android:maxLines="1" />

        <TextView android:id="@+id/widgetNameFajr"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:text="الفجر" android:textColor="#c8a86a" android:textSize="12sp"
            android:gravity="center" android:maxLines="1" />
    </LinearLayout>

    <!-- ── Ligne 3 : heures des 5 prières (même ordre RTL) ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView android:id="@+id/widgetTimeIsha"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:text="--:--" android:textColor="#f5e6c8" android:textSize="14sp"
            android:textStyle="bold" android:gravity="center" android:maxLines="1" />

        <TextView android:id="@+id/widgetTimeMgrb"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:text="--:--" android:textColor="#f5e6c8" android:textSize="14sp"
            android:textStyle="bold" android:gravity="center" android:maxLines="1" />

        <TextView android:id="@+id/widgetTimeAssr"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:text="--:--" android:textColor="#f5e6c8" android:textSize="14sp"
            android:textStyle="bold" android:gravity="center" android:maxLines="1" />

        <TextView android:id="@+id/widgetTimeDohr"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:text="--:--" android:textColor="#f5e6c8" android:textSize="14sp"
            android:textStyle="bold" android:gravity="center" android:maxLines="1" />

        <TextView android:id="@+id/widgetTimeFajr"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:text="--:--" android:textColor="#f5e6c8" android:textSize="14sp"
            android:textStyle="bold" android:gravity="center" android:maxLines="1" />
    </LinearLayout>

    <!-- ── Ligne 4 : barre d'accent fine sous la prière en cours (remplace -->
    <!-- l'ancien fond plein "carré" — un simple repère discret par colonne). -->
    <!-- TextView vide (pas <View>) : RemoteViews (widgets écran d'accueil) -->
    <!-- n'autorise qu'un jeu restreint de classes de vues — <View> brut n'en -->
    <!-- fait pas partie et fait échouer l'inflation ("impossible d'ajouter -->
    <!-- le widget"), d'où le séparateur juste au-dessus qui utilise déjà -->
    <!-- une TextView vide pour la même raison. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_marginTop="2dp"
        android:orientation="horizontal">

        <TextView android:id="@+id/widgetAccentIsha"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:layout_marginStart="12dp" android:layout_marginEnd="12dp"
            android:text=""
            android:background="@drawable/widget_accent_bar" android:visibility="invisible" />

        <TextView android:id="@+id/widgetAccentMgrb"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:layout_marginStart="12dp" android:layout_marginEnd="12dp"
            android:text=""
            android:background="@drawable/widget_accent_bar" android:visibility="invisible" />

        <TextView android:id="@+id/widgetAccentAssr"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:layout_marginStart="12dp" android:layout_marginEnd="12dp"
            android:text=""
            android:background="@drawable/widget_accent_bar" android:visibility="invisible" />

        <TextView android:id="@+id/widgetAccentDohr"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:layout_marginStart="12dp" android:layout_marginEnd="12dp"
            android:text=""
            android:background="@drawable/widget_accent_bar" android:visibility="invisible" />

        <TextView android:id="@+id/widgetAccentFajr"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:layout_marginStart="12dp" android:layout_marginEnd="12dp"
            android:text=""
            android:background="@drawable/widget_accent_bar" android:visibility="invisible" />
    </LinearLayout>

</LinearLayout>
